#!/bin/bash -

export DEV_ROOT=/home/jgiovatto/Devel

# back to top level
SRSRAN4G_ROOT=`pwd`/../../..

# default build dir
SRSRAN4G_BIN_DIR=$SRSRAN4G_ROOT/build


OPEN5GS_ROOT=$DEV_ROOT/open5gs

OPEN5GS_BIN_DIR=$OPEN5GS_ROOT/install


echo "using DEV_ROOT      = $DEV_ROOT"
echo "using SRSRAN4G_ROOT = $SRSRAN4G_ROOT"
echo "using OPEN5GS_ROOT  = $OPEN5GS_ROOT"

export LD_LIBRARY_PATH=\
$SRSRAN4G_BIN_DIR/lib/src/phy/rf/:\
$OPEN5GS_BIN_DIR/lib64:\
$LD_LIBRARY_PATH

export PATH=\
$SRSRAN4G_BIN_DIR/srsenb/src:\
$SRSRAN4G_BIN_DIR/srsue/src:\
$SRSRAN4G_BIN_DIR/srsepc/src:\
$OPEN5GS_BIN_DIR/bin:\
$PATH
