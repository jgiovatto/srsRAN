#!/bin/bash -

export DEV_ROOT=/home/jgiovatto/Devel

SRSRAN_4G_ROOT=$DEV_ROOT/srsRAN_4G
SRSRAN_4G_BIN_DIR=$SRSRAN_4G_ROOT/build

SRSRAN_5G_ROOT=$DEV_ROOT/srsRAN_5G
SRSRAN_5G_BIN_DIR=$SRSRAN_5G_ROOT/build

OPEN5GS_ROOT=$DEV_ROOT/open5gs
OPEN5GS_BIN_DIR=$OPEN5GS_ROOT/install



echo "using DEV_ROOT       = $DEV_ROOT"
echo "using SRSRAN_4G_ROOT = $SRSRAN_4G_ROOT"
echo "using SRSRAN_5G_ROOT = $SRSRAN_5G_ROOT"
echo "using OPEN5GS_ROOT   = $OPEN5GS_ROOT"

export LD_LIBRARY_PATH=\
$SRSRAN_4G_BIN_DIR/lib/src/phy/rf/:\
$OPEN5GS_BIN_DIR/lib64:\
$SRSRAN_5G_BIN_DIR/lib/radio/zmq/:\
$LD_LIBRARY_PATH

export PATH=\
$SRSRAN_4G_BIN_DIR/srsenb/src:\
$SRSRAN_4G_BIN_DIR/srsue/src:\
$SRSRAN_4G_BIN_DIR/srsepc/src:\
$SRSRAN_5G_BIN_DIR/apps/gnb:\
$OPEN5GS_BIN_DIR/bin:\
$PATH
