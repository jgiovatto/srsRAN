############################
installing open5gs

https://github.com/open5gs/open5gs

sudo dnf install tunctl mongo-c-driver-devel libyaml-devel libmicrohttpd-devel libgcrypt-devel libidn-devel libnghttp2-devel libcurl-devel install meson ninja-build libtalloc-devel flex bison

meson setup build --prefix=`pwd`/install
ninja -C build
cd build
ninja install

# grab open5gs-dbctl here:
wget https://raw.githubusercontent.com/open5gs/open5gs/main/misc/db/open5gs-dbctl


